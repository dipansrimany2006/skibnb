{
  "name": "ski",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && wrangler dev",
    "cf:deploy": "opennextjs-cloudflare build && wrangler deploy",
    "db:migrate": "wrangler d1 execute ski --file=schema.sql",
    "db:migrate:local": "wrangler d1 execute ski --local --file=schema.sql",
    "db:migrate:v2:local": "wrangler d1 execute ski --local --file=migrate_v2.sql",
    "db:migrate:v2": "wrangler d1 execute ski --remote --file=migrate_v2.sql",
    "types": "wrangler types --env-interface CloudflareEnv"
  },
  "dependencies": {
    "@injectivelabs/networks": "^1.19.26",
    "@injectivelabs/sdk-ts": "^1.19.26",
    "@neondatabase/serverless": "^1.1.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "@privy-io/react-auth": "^3.29.2",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.1",
    "groq-sdk": "^1.2.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.52.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260603.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.97.0"
  }
}
